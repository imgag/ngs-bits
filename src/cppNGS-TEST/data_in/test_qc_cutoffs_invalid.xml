<?xml version="1.0" encoding="UTF-8"?>
<QcRules>
    <SysTypeRules type="lrGS" tumor="false">
        
        <TermRules term_name="target region read depth">
            <Rule operation="less than" cutoff="25.0" result="bad"/>
            <Rule operation="less equal" cutoff="30.0" result="medium"/>
            <Rule operation="greater than" cutoff="30.0" result="good"/>
        </TermRules>

        <TermRules term_name="target region 20x percentage">
            <Rule operation="less than" cutoff="85.0" result="bad"/>
            <Rule operation="less equal" cutoff="95.0" result="medium"/>
            <Rule operation="greater than" cutoff="95.0" result="good"/>
    	</TermRules>

		<TermRules term_name="SNV allele frequency deviation">
            <Rule operation="greater than" cutoff="6.0" result="bad"/>
            <Rule operation="greater equal" cutoff="4.0" result="medium"/>
            <Rule operation="less than" cutoff="4.0" result="good"/>
        </TermRules>

		<TermRules term_name="N50 read length (bp)">
			<Rule operation="less than" cutoff="10000.0" result="medium"/>
			<Rule operation="greater equal" cutoff="10000.0" result="good"/>
		</TermRules>

        <TermRules term_name="known variants percentage">
			<Rule operation="less than" cutoff="97.0" result="bad"/>
			<Rule operation="less than" cutoff="98.5" result="medium"/>
		</TermRules>

    </SysTypeRules>

    <SysTypeRules type="WGS" tumor="false">

        <TermRules1 term_name="target region read depth">
            <Rule operation="less than" cutoff="25.0" result="bad"/>
            <Rule operation="less equal" cutoff="30.0" result="medium"/>
            <Rule operation="greater than" cutoff="30.0" result="good"/>
        </TermRules1>

        <TermRules term_name="target region 20x percentage">
            <Rule operation="less than" cutoff="95.0" result="bad"/>
            <Rule operation="less equal" cutoff="98.0" result="medium"/>
            <Rule operation="greater than" cutoff="98.0" result="good"/>
        </TermRules>

    </SysTypeRules>

    <SysTypeRules type="WES" tumor="false">

        <TermRules term_name="target region read depth">
            <Rule operation="less than" cutoff="80.0" result="bad"/>
            <Rule operation="less equal" cutoff="100.0" result="medium"/>
            <Rule operation="greater than" cutoff="100.0" result="good"/>
        </TermRules>

        <TermRules term_name="target region 20x percentage">
            <Rule operation="less than" cutoff="90.0" result="bad"/>
            <Rule operation="less equal" cutoff="95.0" result="medium"/>
            <Rule operation="greater than" cutoff="95.0" result="good"/>
        </TermRules>

        <TermRules term_name="SNV allele frequency deviation">
            <Rule5 operation="greater than" cutoff="6.0" result="bad"/>
            <Rule operation="greater equal" cutoff="3.0" result="medium"/>
            <Rule operation="less than" cutoff="3.0" result="good"/>
        </TermRules>

        <TermRules term_name="known variants percentage">
			<Rule operation="less than" cutoff="98.0" result="bad"/>
			<Rule operation="less than" cutoff="99.0" result="medium"/>
		</TermRules>
        
     </SysTypeRules>

    </SysNameRules>
</QcRules>
